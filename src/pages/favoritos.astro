---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import SitesGrid from '../components/SitesGrid';
---

<DashboardLayout title="Meus Favoritos">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Seus Templates Salvos</h1>
    <p class="text-gray-500 mt-1">Aqui estão todos os templates que você marcou com ❤️ para usar depois.</p>
  </div>
  
  <SitesGrid client:load showOnlyFavorites={true} />
</DashboardLayout>
