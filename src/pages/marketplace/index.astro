---
import PublicLayout from '../../layouts/PublicLayout.astro';
import MarketplaceGrid from '../../components/marketplace/MarketplaceGrid';
import { supabase } from '../../lib/supabase';
import type { Listing } from '../../lib/marketplace-types';

const { data } = await supabase
  .from('marketplace_listings')
  .select('*')
  .eq('status', 'published')
  .order('published_at', { ascending: false });

const listings: Listing[] = data ?? [];
---

<PublicLayout title="Marketplace" description="Templates prontos para baixar e usar no seu site.">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Marketplace</h1>
    <p class="text-gray-500 mt-1.5 text-sm max-w-lg">
      Templates prontos criados nas aulas do Meu Site Com IA. Baixe, customize e coloque no ar.
    </p>
  </div>

  <MarketplaceGrid initialListings={listings} client:load />
</PublicLayout>
