---
import '../styles/global.css';
import { LogOut, LayoutDashboard, Settings, Shield, Menu, X, GraduationCap, Globe, LifeBuoy, Vote, DollarSign, HelpCircle } from 'lucide-react';
import GroupWizard from '../components/GroupWizard';
import TokenGate from '../components/TokenGate';

interface Props {
	title: string;
}

const { title } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Meu Site Com IA</title>
        
	</head>
	<body class="bg-papel-craft text-carvao-quente flex h-screen overflow-hidden">
    <!-- Overlay Mobile -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-carvao-quente/40 z-40 lg:hidden opacity-0 invisible transition-all duration-300"></div>

    <!-- Sidebar -->
    <aside id="sidebar" aria-hidden="true" class="fixed lg:static inset-y-0 left-0 w-64 bg-cream-elevated border-r border-borda-cafe flex flex-col h-full z-50 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
      <div class="h-16 flex items-center justify-between px-6 border-b border-borda-cafe shrink-0">
        <h1 class="font-display text-xl font-medium tracking-tight text-coral-terra">Meu Site Com IA</h1>
        <button id="close-sidebar" aria-label="Fechar menu" class="lg:hidden p-2 text-cafe-medio hover:bg-coral-wash hover:text-terracota-profundo rounded-md">
          <X className="w-5 h-5" />
        </button>
      </div>
      
      <nav class="flex-1 p-4 overflow-y-auto space-y-1">

        {/* ── 3 itens core (Jobs to be Done identificados) ── */}

        {/* Visão Geral — home do dashboard */}
        <a
          href="/dashboard"
          class={`flex items-center gap-3 px-3 py-2.5 rounded-[8px] transition-colors ${
            pathname === '/dashboard'
              ? 'bg-cream-surface text-coral-terra font-semibold'
              : 'text-cafe-medio hover:bg-coral-wash hover:text-terracota-profundo'
          }`}
        >
          <LayoutDashboard className="w-4 h-4 shrink-0" />
          <span class="text-sm">Visão Geral</span>
        </a>

        {/* Meus sites — carteira (job principal: gerir/expandir carteira) */}
        <a
          href="/meus-sites"
          class={`flex items-center gap-3 px-3 py-2.5 rounded-[8px] transition-colors ${
            pathname.includes('/meus-sites') || pathname === '/sites'
              ? 'bg-cream-surface text-coral-terra font-semibold'
              : 'text-cafe-medio hover:bg-coral-wash hover:text-terracota-profundo'
          }`}
        >
          <Globe className="w-4 h-4 shrink-0" />
          <span class="text-sm">Meus sites</span>
        </a>

        {/* Academy — curso (job secundário #1) */}
        <a
          href="/aulas"
          class={`flex items-center gap-3 px-3 py-2.5 rounded-[8px] transition-colors ${
            pathname === '/aulas' || pathname.includes('/aulas-ao-vivo')
              ? 'bg-cream-surface text-coral-terra font-semibold'
              : 'text-cafe-medio hover:bg-coral-wash hover:text-terracota-profundo'
          }`}
        >
          <GraduationCap className="w-4 h-4 shrink-0" />
          <span class="text-sm">Academy</span>
        </a>

        {/* Afiliados — programa de comissões 50% */}
        <a
          href="/afiliados"
          class={`flex items-center gap-3 px-3 py-2.5 rounded-[8px] transition-colors ${
            pathname.includes('/afiliados')
              ? 'bg-cream-surface text-coral-terra font-semibold'
              : 'text-cafe-medio hover:bg-coral-wash hover:text-terracota-profundo'
          }`}
        >
          <DollarSign className="w-4 h-4 shrink-0" />
          <span class="text-sm">Afiliados</span>
        </a>

        {/* Ajuda — FAQ self-service */}
        <a
          href="/ajuda"
          class={`flex items-center gap-3 px-3 py-2.5 rounded-[8px] transition-colors ${
            pathname.includes('/ajuda')
              ? 'bg-cream-surface text-coral-terra font-semibold'
              : 'text-cafe-medio hover:bg-coral-wash hover:text-terracota-profundo'
          }`}
        >
          <HelpCircle className="w-4 h-4 shrink-0" />
          <span class="text-sm">Ajuda</span>
        </a>

      </nav>

      {/* Footer da sidebar — utilitários minimalistas (não compete com itens core) */}
      <div class="px-4 py-3 border-t border-borda-cafe space-y-0.5 shrink-0">
        <a
          href="/configuracoes"
          class={`flex items-center gap-3 px-3 py-1.5 rounded-[8px] text-xs transition-colors ${
            pathname.includes('/configuracoes')
              ? 'text-coral-terra font-semibold'
              : 'text-cafe-cinza-quente hover:text-terracota-profundo'
          }`}
        >
          <Settings className="w-3.5 h-3.5 shrink-0" />
          <span>Configurações</span>
        </a>
      </div>
    </aside>

    <main class="flex-1 flex flex-col h-full overflow-hidden min-w-0">
      <header class="h-16 bg-papel-craft border-b border-borda-cafe flex items-center justify-between px-4 lg:px-8 shrink-0">
        <div class="flex items-center gap-4">
          <button id="open-sidebar" aria-label="Abrir menu de navegacao" class="lg:hidden w-11 h-11 flex items-center justify-center text-cafe-medio hover:bg-coral-wash hover:text-terracota-profundo rounded-md">
            <Menu className="w-6 h-6" />
          </button>
          <h2 class="font-display text-2xl font-normal text-carvao-quente tracking-tight truncate">{title}</h2>
        </div>

        {/* Lado direito: chip de votação (condicional) + avatar */}
        <div class="flex items-center gap-3">

          {/* Chip de votação — começa hidden, script ativa se votação aberta */}
          <a
            id="voting-chip"
            href="/comunidade"
            hidden
            aria-label="Votação aberta — votar no próximo template"
            title="Votação aberta — clique pra votar"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-coral-wash text-coral-terra rounded-full text-xs font-semibold hover:bg-coral-terra hover:text-papel-craft transition-colors min-h-[36px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-coral-terra"
          >
            <Vote className="w-3.5 h-3.5" />
            <span class="hidden sm:inline">Votação aberta</span>
          </a>

        {/* DROPDOWN MENU */}
        <div id="header-menu-wrapper" class="relative h-full flex items-center">
          <button
            id="header-menu-btn"
            type="button"
            aria-label="Menu da conta"
            aria-expanded="false"
            class="flex items-center justify-center w-10 h-10 rounded-full bg-coral-terra hover:bg-terracota-profundo transition-colors text-papel-craft text-sm font-semibold tracking-wide focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-coral-terra"
          >
            <span id="user-initials">—</span>
          </button>

          {/* MENU FLUTUANTE */}
          <div id="header-menu-panel" class="absolute right-0 top-full pt-1 w-56 opacity-0 invisible transition-all duration-200 z-50">
            <div class="bg-cream-surface border border-borda-cafe rounded-[12px] shadow-[0_12px_32px_-12px_rgba(80,40,20,0.12)] p-2 flex flex-col gap-1 transform origin-top-right scale-95 transition-transform duration-200">
              <div class="px-3 py-2 border-b border-borda-cafe mb-1">
                <p class="text-xs font-bold tracking-widest text-cafe-cinza-quente uppercase">Sua Conta</p>
              </div>
              <a href="/configuracoes" class="px-3 py-2.5 text-sm font-semibold text-cafe-medio hover:bg-coral-wash hover:text-terracota-profundo rounded-[8px] transition-colors text-left flex items-center gap-2">
                Conta
              </a>
              <a href="/configuracoes?tab=integracao" class="px-3 py-2.5 text-sm font-semibold text-cafe-medio hover:bg-coral-wash hover:text-terracota-profundo rounded-[8px] transition-colors text-left flex items-center gap-2">
                Integrações
              </a>
              <a
                id="admin-link-header"
                href="/admin"
                style="display: none;"
                class="px-3 py-2.5 text-sm font-extrabold text-coral-terra hover:bg-coral-wash hover:text-terracota-profundo rounded-[8px] transition-colors text-left items-center gap-2"
              >
                <Shield className="w-4 h-4" />
                Área Admin
              </a>
              <div class="h-px bg-borda-cafe my-1 mx-1"></div>
              <button id="logout-btn" class="px-3 py-2.5 text-sm font-semibold text-vermelho-tijolo hover:bg-coral-wash rounded-[8px] transition-colors text-left flex items-center gap-2 w-full">
                <LogOut className="w-4 h-4" />
                Sair da Plataforma
              </button>
            </div>
          </div>
        </div>
        </div>
      </header>

      <script is:inline>
        // Mostra chip "Votação aberta" no header durante o ciclo (Dom 00h → Sáb 12h BRT).
        (() => {
            function isVotingOpen() {
                const now = new Date();
                const dow = now.getUTCDay();
                if (dow === 6) return now.getUTCHours() < 15;  // sábado: aberta até 12h BRT (15h UTC)
                const daysToSat = (6 - dow + 7) % 7;
                const close = new Date(now);
                close.setUTCDate(now.getUTCDate() + daysToSat);
                close.setUTCHours(15, 0, 0, 0);
                if (close.getTime() <= now.getTime()) close.setUTCDate(close.getUTCDate() + 7);
                return close.getTime() > now.getTime();
            }
            const chip = document.getElementById('voting-chip');
            if (chip && isVotingOpen()) chip.removeAttribute('hidden');
        })();

        (() => {
            const btn = document.getElementById('header-menu-btn');
            const panel = document.getElementById('header-menu-panel');
            if (!btn || !panel) return;
            const inner = panel.firstElementChild;

            const open = () => {
                panel.classList.remove('opacity-0', 'invisible');
                panel.classList.add('opacity-100', 'visible');
                if (inner) inner.classList.replace('scale-95', 'scale-100');
                btn.setAttribute('aria-expanded', 'true');
            };
            const close = () => {
                panel.classList.add('opacity-0', 'invisible');
                panel.classList.remove('opacity-100', 'visible');
                if (inner) inner.classList.replace('scale-100', 'scale-95');
                btn.setAttribute('aria-expanded', 'false');
            };
            const toggle = (e) => {
                e.stopPropagation();
                const isOpen = btn.getAttribute('aria-expanded') === 'true';
                isOpen ? close() : open();
            };

            btn.addEventListener('click', toggle);
            document.addEventListener('click', (e) => {
                if (!panel.contains(e.target) && !btn.contains(e.target)) close();
            });
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
        })();
      </script>
      
      <div class="flex-1 overflow-y-auto p-4 lg:p-8">
        <slot />
      </div>

      <GroupWizard client:load />
      <TokenGate client:load />
    </main>

    {/* ── FAB Ajuda (Job #3: tirar dúvida rápida quando trava) ── */}
    <a
      href="/ajuda"
      aria-label="Abrir ajuda"
      class="fixed bottom-6 right-6 z-40 inline-flex items-center gap-2 bg-carvao-quente hover:bg-coral-terra text-papel-craft pl-4 pr-5 py-3 rounded-full font-semibold text-sm transition-all hover:-translate-y-0.5 active:scale-[0.97] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-coral-terra min-h-[48px]"
      style="box-shadow: 0 10px 25px -5px rgba(80, 40, 20, 0.25), 0 4px 6px -2px rgba(80, 40, 20, 0.10);"
    >
      <HelpCircle className="w-4 h-4" />
      <span class="hidden sm:inline">Ajuda</span>
    </a>

    <script>
      import { supabase } from '../lib/supabase';
      
      // Menu Mobile Toggle
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      const openBtn = document.getElementById('open-sidebar');
      const closeBtn = document.getElementById('close-sidebar');

      function toggleSidebar() {
        const isHidden = sidebar?.getAttribute('aria-hidden') !== 'false';
        sidebar?.classList.toggle('-translate-x-full');
        overlay?.classList.toggle('opacity-0');
        overlay?.classList.toggle('invisible');
        sidebar?.setAttribute('aria-hidden', isHidden ? 'false' : 'true');
      }

      openBtn?.addEventListener('click', toggleSidebar);
      closeBtn?.addEventListener('click', toggleSidebar);
      overlay?.addEventListener('click', toggleSidebar);

      async function handleLogout() {
        await supabase.auth.signOut();
        window.location.href = '/';
      }

      document.getElementById('logout-btn')?.addEventListener('click', handleLogout);


      // Checa sessão + popula iniciais do avatar (Café-da-Tarde)
      supabase.auth.getSession().then(({ data: { session } }) => {
        if (!session) {
          window.location.href = '/';
        } else {
          const fullName = (session.user.user_metadata as Record<string, unknown> | null)?.full_name as string | undefined;
          const email = session.user.email;
          let initials = '—';
          if (fullName && fullName.trim()) {
            const parts = fullName.trim().split(/\s+/);
            initials = parts.length >= 2
              ? (parts[0][0] + parts[parts.length - 1][0]).toUpperCase()
              : parts[0].slice(0, 2).toUpperCase();
          } else if (email) {
            initials = email.slice(0, 2).toUpperCase();
          }
          const initialsEl = document.getElementById('user-initials');
          if (initialsEl) initialsEl.textContent = initials;

          supabase.from('profiles').select('role').eq('id', session.user.id)
            .then(({ data }) => {
              if (data && data.some(p => p.role === 'admin')) {
                const adminLink = document.getElementById('admin-link-header');
                if (adminLink) adminLink.style.display = 'flex';
              }
            });
        }
      });
    </script>
	</body>
</html>
