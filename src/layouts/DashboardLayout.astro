---
import '../styles/global.css';
import { LogOut, LayoutDashboard, Settings, Shield, Heart, BookOpen } from 'lucide-react';

interface Props {
	title: string;
}

const { title } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Meu Site Com IA</title>
	</head>
	<body class="bg-gray-50 text-gray-900 flex h-screen overflow-hidden">
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col h-full">
      <div class="h-16 flex items-center px-6 border-b border-gray-200">
        <h1 class="text-xl font-bold text-[#7c3aed]">Meu Site Com IA</h1>
      </div>
      
      <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
        <a 
          href="/sites" 
          class={`flex items-center gap-3 px-3 py-2 rounded-md transition-colors ${
            pathname.includes('/sites') 
              ? 'bg-[#7c3aed]/10 text-[#7c3aed] font-medium' 
              : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'
          }`}
        >
          <LayoutDashboard className="w-5 h-5" />
          Sites
        </a>
        <a 
          href="/favoritos" 
          class={`flex items-center gap-3 px-3 py-2 rounded-md transition-colors ${
            pathname.includes('/favoritos') 
              ? 'bg-[#7c3aed]/10 text-[#7c3aed] font-medium' 
              : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'
          }`}
        >
          <Heart className="w-5 h-5" />
          Favoritos
        </a>
        <a 
          href="/como-usar" 
          class={`flex items-center gap-3 px-3 py-2 rounded-md transition-colors ${
            pathname.includes('/como-usar') 
              ? 'bg-[#7c3aed]/10 text-[#7c3aed] font-medium' 
              : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'
          }`}
        >
          <BookOpen className="w-5 h-5" />
          Como Usar
        </a>
      </nav>
    </aside>

    <main class="flex-1 flex flex-col h-full overflow-hidden">
      <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8">
        <h2 class="text-lg font-semibold text-gray-800">{title}</h2>
        
        {/* DROPDOWN MENU */}
        <div class="relative group h-full flex items-center">
          <button class="flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition text-gray-600 outline-none">
            <Settings className="w-5 h-5" />
          </button>
          
          {/* MENU FLUTUANTE INVISÍVEL ATÉ TER HOVER NO ÍCONE ACIMA */}
          <div class="absolute right-0 top-full pt-1 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="bg-white border border-gray-100 rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] p-2 flex flex-col gap-1 transform origin-top-right group-hover:scale-100 scale-95 transition-transform duration-200">
              <div class="px-3 py-2 border-b border-gray-50 mb-1">
                <p class="text-[10px] font-bold tracking-widest text-gray-400 uppercase">Sua Conta</p>
              </div>
              <a href="/configuracoes" class="px-3 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 hover:text-[#7c3aed] rounded-xl transition-colors text-left flex items-center gap-2">
                Conta
              </a>
              <a href="/configuracoes?tab=integracao" class="px-3 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 hover:text-[#7c3aed] rounded-xl transition-colors text-left flex items-center gap-2">
                Integrações
              </a>
              <a 
                id="admin-link-header"
                href="/admin" 
                style="display: none;"
                class="px-3 py-2.5 text-sm font-extrabold text-[#7c3aed] hover:bg-[#7c3aed]/10 rounded-xl transition-colors text-left items-center gap-2"
              >
                <Shield className="w-4 h-4" />
                Área Admin
              </a>
              <div class="h-px bg-gray-100 my-1 mx-1"></div>
              <button id="logout-btn" class="px-3 py-2.5 text-sm font-semibold text-red-600 hover:bg-red-50 rounded-xl transition-colors text-left flex items-center gap-2 w-full">
                <LogOut className="w-4 h-4" />
                Sair da Plataforma
              </button>
            </div>
          </div>
        </div>
      </header>
      
      <div class="flex-1 overflow-y-auto p-8">
        <slot />
      </div>
    </main>

    <script>
      import { supabase } from '../lib/supabase';
      
      async function handleLogout() {
        await supabase.auth.signOut();
        window.location.href = '/';
      }

      document.getElementById('logout-btn')?.addEventListener('click', handleLogout);
      
      // Checa sessão
      supabase.auth.getSession().then(({ data: { session } }) => {
        if (!session) {
          window.location.href = '/';
        } else {
          supabase.from('profiles').select('role').eq('id', session.user.id).single()
            .then(({ data }) => {
              if (data?.role === 'admin') {
                const adminLink = document.getElementById('admin-link-header');
                if (adminLink) adminLink.style.display = 'flex';
              }
            });
        }
      });
    </script>
	</body>
</html>
